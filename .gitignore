# ============================================================================
# .gitignore — keep credentials, machine-specific overrides, and caches out.
# ============================================================================

# Local overrides (machine-specific) — never committed.
*.local
*.private

# Environment files
.env
.env.*
!.env.example

# SSH — never commit keys or known_hosts
ssh/id_*
ssh/*.pub
ssh/known_hosts*
ssh/authorized_keys

# Kerberos
*.keytab

# GPG
*.gpg
*.asc
!*.pub.asc

# Generic credential / key patterns
*.pem
*.key
*.p12
*.pfx
credentials
.netrc

# Belt-and-braces: never commit a real api-keys.zsh by mistake.
shell/env.d/3-api-keys.zsh
shell/env.d/*-secrets.zsh
shell/env.d/*-keys.zsh
shell/env.d/*-tokens.zsh

# Shell histories & caches
.*_history
.cache/
.zcompdump*
.zsh_sessions/

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~

# Note: stow/ IS tracked. It contains symlinks generated by build-stow-tree.sh
# pointing back into the source-of-truth files. Run that script if files move.