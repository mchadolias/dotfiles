# ============================================================================
# ~/.zshrc — INTERACTIVE shells only.
# This file is universal. Heavy / environment-specific tool init
# (conda, mamba, julia, fastfetch, kitty integration, etc.) lives in
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Universal aliases
# ----------------------------------------------------------------------------
# Load DOTFILES var from zshenv, then aliases (shared with bash) from a separate file.
DOTFILES="${DOTFILES:-$HOME/dotfiles}"
[[ -r "$DOTFILES/shell/aliases/general.sh" ]] && source "$DOTFILES/shell/aliases/general.sh"

# ----------------------------------------------------------------------------
# 2. Completion (must precede plugins that register completions)
# ----------------------------------------------------------------------------
autoload -Uz compinit
compinit -d "$XDG_CACHE_HOME/zsh/.zcompdump"

# ----------------------------------------------------------------------------
# 3. Modular config drop-in directory
# Anything in $ZDOTDIR/env.d/*.zsh gets sourced. Useful for one-off
# additions you don't want in the main file.
# ----------------------------------------------------------------------------
if [[ -d "$ZDOTDIR/env.d" ]]; then
	for f in "$ZDOTDIR/env.d"/*.zsh(N); do
		[[ -r "$f" ]] && source "$f"
	done
fi

# ----------------------------------------------------------------------------
# 4. Prompt — Starship (deferred so compinit finishes first)
# ----------------------------------------------------------------------------
if command -v starship >/dev/null 2>&1; then
	autoload -Uz add-zsh-hook
	_starship_init_once() {
		eval "$(starship init zsh)"
		add-zsh-hook -d precmd _starship_init_once
		unset -f _starship_init_once
	}
	add-zsh-hook precmd _starship_init_once
fi

# ----------------------------------------------------------------------------
# 5. zoxide — `j` for jump, leaves `cd` untouched
# ----------------------------------------------------------------------------
if command -v zoxide >/dev/null 2>&1; then
	eval "$(zoxide init zsh --cmd j)"
fi

# ----------------------------------------------------------------------------
# 6. Universal helper functions
# ----------------------------------------------------------------------------
mkcd() { mkdir -p -- "$1" && cd -- "$1"; }

# Yazi: cd into the directory yazi exits in.
y() {
	local tmp cwd
	tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[[ -n "$cwd" && "$cwd" != "$PWD" && -d "$cwd" ]] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# ----------------------------------------------------------------------------
# 7. Machine-specific overrides (identity, secrets, ad-hoc tweaks)
# ----------------------------------------------------------------------------
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# ----------------------------------------------------------------------------
# 8. Profile dispatch
# ----------------------------------------------------------------------------

for _ext in zsh sh; do
	_profile_file="$DOTFILES/shell/profiles/${DOTFILES_PROFILE}.${_ext}"
	if [[ -r "$_profile_file" ]]; then
		source "$_profile_file"
		break
	fi
done
unset _ext _profile_file
